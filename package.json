{
  "name": "stratiq",
  "private": true,
  "workspaces": [
    "web",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --prefix web run dev",
    "dev:api": "python3 -m uvicorn api.app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:all": "sh -c 'npm run dev:api & npm run dev:web'",
    "build": "npm run build:web",
    "build:web": "npm --prefix web run build",
    "lint": "npm --prefix web run lint",
    "typecheck": "npm --prefix web run typecheck"
  }
}
